# ─────────────────────────────────────────────────────────────────────────────
# Foodipe — Environment Variables Template
# Copy this file to a ROOT-LEVEL .env (never commit the real .env to git)
# and fill in the values below before running docker-compose.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB admin password (used by both the mongo container and the backend URI)
MONGO_ROOT_PASSWORD=change_me_to_a_strong_password

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_64_byte_hex_string

# OpenAI API key
OPENAI_API_KEY=sk-...

# Allowed frontend origin(s) for CORS (comma-separated for multiple)
# Production example: https://foodipe.redptam.dom
# Development default: http://localhost:5173
CORS_ORIGIN=http://localhost:5173
